# Copy this file to .env and fill in what you have. Nothing here is required
# to just start the process — see src/config/env.ts / README for exactly
# which features turn on with which keys. Only SUPABASE_URL and
# SUPABASE_SERVICE_ROLE_KEY are truly required to boot at all.

# ─── Core infra (required) ──────────────────────────────────────────────
# Supabase project settings → API. Use the service_role key (not anon) —
# this runs server-side only and needs to bypass row-level security.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis for BullMQ. Local dev: run `docker run -p 6379:6379 redis` and leave
# the default below. Render/production: use your Render Redis instance URL.
REDIS_URL=redis://localhost:6379

# ─── Email sending (Amazon SES) ─────────────────────────────────────────
# Leave these blank to disable email sending entirely — the app still runs,
# it just skips the email queue (see printConfigSummary() at startup).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Must be a verified identity in SES (or your whole domain, once out of
# sandbox mode). Use a subdomain for cold email, e.g. outreach@yourdomain.com
# — see README "Email setup" for why.
SES_FROM_EMAIL=
SES_FROM_NAME=Karan
# Where replies go, and what CAN-SPAM's unsubscribe mechanism points to.
REPLY_TO_EMAIL=
# Required by CAN-SPAM on every commercial email you send.
COMPANY_PHYSICAL_ADDRESS=

# ─── Email finding (enrichment waterfall) ───────────────────────────────
# All three are optional and independent — set as many as you want, the
# waterfall skips any that are missing. Free tiers: Prospeo 75/mo, Hunter
# 50/mo, Snov 50/mo — comfortably covers this project's volume at $0.
PROSPEO_API_KEY=
HUNTER_API_KEY=
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# ─── Reply polling (IMAP) ────────────────────────────────────────────────
# Works with a Gmail App Password (Google Account → Security → 2-Step
# Verification → App Passwords) — no OAuth consent screen needed. Point
# this at whatever inbox REPLY_TO_EMAIL delivers to.
REPLY_IMAP_HOST=imap.gmail.com
REPLY_IMAP_PORT=993
REPLY_IMAP_USER=
REPLY_IMAP_PASSWORD=

# ─── X / Twitter (cookie auth, not the paid API) ────────────────────────
# From a browser logged into the X account you want to scrape/send from:
# DevTools → Application → Cookies → x.com → copy the values of
# `auth_token` and `ct0`. Use a SECONDARY account, not your main one — see
# README "X/Twitter setup and risk" before turning sending on.
X_AUTH_TOKEN=
X_CT0=
X_ACCOUNT_LABEL=secondary-account
# Max DMs/day. Keep this conservative — see README for why 20 is the
# starting default and not a number to raise casually.
X_DM_DAILY_LIMIT=20
X_DM_MIN_DELAY_SECONDS=200
X_DM_MAX_DELAY_SECONDS=420

# ─── Safety guardrails ───────────────────────────────────────────────────
# X DM sending auto-pauses if the failed+negative-reply rate over the last
# 24h hits this fraction, once at least CIRCUIT_BREAKER_MIN_SAMPLE sends
# have happened (so it won't trip on a tiny early sample).
CIRCUIT_BREAKER_NEGATIVE_RATE_THRESHOLD=0.15
CIRCUIT_BREAKER_MIN_SAMPLE=5

# ─── Scheduling ───────────────────────────────────────────────────────────
# Standard cron syntax. Other stages (enrich/send/replies) are scheduled
# relative to this in src/queue/scheduler.ts — edit there if you want to
# change their offsets too.
SCRAPE_CRON=0 8 * * *
LOG_LEVEL=info
